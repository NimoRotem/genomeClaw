# =============================================================================
# 23andClaude — Environment Variables
# =============================================================================
# Copy this file to .env at the repo root and fill in real values.
# Each sub-app (main, ancestry) reads from environment variables it needs.
#
# DO NOT commit .env. It is excluded by .gitignore.

# -- Authentication ---------------------------------------------------------
# JWT signing key for the main genomics dashboard. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-hex-string

# -- AI / LLM ---------------------------------------------------------------
# Used by the AI report generator and the in-app Claude Code chat tab.
ANTHROPIC_API_KEY=sk-ant-...
AI_REPORT_MODEL=claude-sonnet-4-20250514

# -- Database ---------------------------------------------------------------
# SQLite is the default; PostgreSQL is also supported.
DATABASE_URL=sqlite:////data/app/db.sqlite
# DATABASE_URL=postgresql://user:pass@localhost:5432/twentythreeandclaude

# -- Redis ------------------------------------------------------------------
# Used by the main app for PGS search caching and pub/sub.
REDIS_URL=redis://localhost:6379/0

# -- Data paths -------------------------------------------------------------
# Where persistent and ephemeral genomics data live.
GENOMICS_DATA_DIR=/data
GENOMICS_SCRATCH_DIR=/scratch

# -- Servers ----------------------------------------------------------------
# Main genomics dashboard (FastAPI)
GENOMICS_PORT=8600

# Ancestry sub-app (FastAPI). Mounted at /ancestry/ behind nginx.
ANCESTRY_PORT=8700

# Where the ancestry app keeps reference data, jobs, and uploads.
APP_ROOT=/data/ancestry_app

# -- Ancestry sample directories --------------------------------------------
# Comma-separated list of directories the ancestry app scans for input files.
SAMPLE_DIRS=/data/aligned_bams,/data/ancestry_app/uploads

# Optional: directory of nimog (BAM-to-VCF converter) outputs to also scan.
NIMOG_OUTPUT_ROOT=/scratch/nimog_output

# Default reference FASTA used when calling variants from BAM/CRAM input.
DEFAULT_FASTA=/data/reference/GRCh38.fa

# -- Tool overrides (optional) ----------------------------------------------
# If your bcftools/samtools/plink2 are not on $PATH, point at a conda env's
# bin directory and the ancestry pipeline will prepend it automatically.
# GENOMICS_BIN=/opt/conda/envs/genomics/bin
# GENOMICS_BCFTOOLS=/path/to/bcftools
# GENOMICS_SAMTOOLS=/path/to/samtools
# GENOMICS_PLINK2=/path/to/plink2

# -- Claude Code chat integration (optional) --------------------------------
# Used by main/backend/api/chat.py to spawn a tmux-hosted Claude session.
# CLAUDE_CMD=/usr/local/bin/claude
# CHAT_TMUX_SESSION=genomics-claude
# CHAT_WORK_DIR=/path/to/main
# CHAT_TMUX_EXTRA_PATH=/home/you/.local/bin:/home/you/.nvm/versions/node/v20/bin

# -- CORS (main app) --------------------------------------------------------
# JSON array or comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:8600
