# =============================================================================
# Secrets — never commit
# =============================================================================
.env
.env.*
*.pem
*.key
*.crt
secrets/
credentials*.json

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*.so
*.egg
*.egg-info/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/
build/
dist/
*.spec
.python-version
venv/
.venv/
env/

# =============================================================================
# Node / Vite
# =============================================================================
node_modules/
**/dist/
**/build/
.vite/
.cache/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# =============================================================================
# Editors / OS
# =============================================================================
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# =============================================================================
# Genomics — large reference data, intermediates, results
# =============================================================================
# Reference panels and FASTA (re-download via setup scripts)
**/reference/*.bed
**/reference/*.bim
**/reference/*.fam
**/reference/*.pgen
**/reference/*.pvar*
**/reference/*.psam
**/reference/*.fa
**/reference/*.fa.gz
**/reference/*.fasta
**/reference/*.fasta.gz
**/reference/*.fai
**/reference/hgdp1kgp_chr*
**/reference/per_chr/
**/reference/hgdp_1kg_all.vcf.gz
**/reference/*.bak
**/reference/*.log
**/reference/*.prune.*
**/reference/*.tsv
**/reference/high_ld_regions_hg38.txt
**/reference/ref_pruned*

# Sample / pipeline outputs
**/uploads/
**/results/
**/scratch/
**/run_nimo_work/
**/run_*_work/
**/output/

# Model weights, containers
*.sif
*.weights

# Database
*.sqlite
*.sqlite3
*.db

# Large genomic file types — never check these in
*.bam
*.bai
*.cram
*.crai
*.vcf
*.vcf.gz
*.tbi
*.gvcf
*.gvcf.gz
*.g.vcf
*.g.vcf.gz
*.fastq
*.fastq.gz
*.fq
*.fq.gz

# =============================================================================
# App-specific runtime state (regenerated)
# =============================================================================
main/nimog/jobs/*.json
main/data/
main/sex_check*
main/plink2.log

