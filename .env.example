# simple-genomics environment configuration
# Copy to .env and fill in values

# Default admin user (created on first run if users.json doesn't exist)
SG_DEFAULT_USER=admin@example.com
SG_DEFAULT_PASSWORD=changeme123

# AI chat integration (optional — users can also set their own keys in the UI)
FALLBACK_ANTHROPIC_KEY=
OPENAI_API_KEY=

# Reference FASTA (default: /data/refs/GRCh38.fa)
REF_FASTA=/data/refs/GRCh38.fa

# Bioinformatics tools (set if not on PATH)
BCFTOOLS=/home/nimo/miniconda3/envs/genomics/bin/bcftools
SAMTOOLS=/home/nimo/miniconda3/envs/genomics/bin/samtools
PLINK2=/home/nimo/miniconda3/envs/genomics/bin/plink2
